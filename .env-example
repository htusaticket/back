# ===========================================
# CONFIGURACIÓN DE ZAZCREDITOS BACKEND
# ===========================================

# Entorno de ejecución
NODE_ENV=development
PORT=5000

# ===========================================
# BASE DE DATOS
# ===========================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zazcreditos"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/zazcreditos"

# ===========================================
# SEGURIDAD Y AUTENTICACIÓN
# ===========================================
# Debe tener al menos 32 caracteres para seguridad
JWT_SECRET="zazcreditos_super_secret_jwt_key_change_this_in_production_32_chars_min"
JWT_EXPIRES_IN=1d

# Rounds de encriptación para bcrypt (10-15 recomendado)
BCRYPT_SALT_ROUNDS=12

# ===========================================
# CORS Y DOMINIOS PERMITIDOS
# ===========================================
# Lista de dominios separados por comas
HOSTS_WHITE_LIST="http://localhost:3000,http://localhost:3001,http://localhost:5173"

# ===========================================
# LOGGING Y OBSERVABILIDAD
# ===========================================
# Niveles: error, warn, info, debug
LOG_LEVEL=debug

# ===========================================
# RATE LIMITING
# ===========================================
# Tiempo en segundos para el rate limit
RATE_LIMIT_TTL=60
# Máximo de requests por TTL
RATE_LIMIT_MAX=100

# ===========================================
# CONFIGURACIONES OPCIONALES
# ===========================================
# Redis (si se usa para cache/sesiones)
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# Configuraciones de email (si se implementa)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
FROM_EMAIL="noreply@zazcreditos.com"

# Configuraciones de terceros (si se implementa)
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_PUBLIC_KEY=""

# ===========================================
# MONITOREO Y OBSERVABILIDAD
# ===========================================
# Sentry DSN para monitoreo de errores (opcional)
# Obtener en: https://sentry.io/settings/[org]/projects/[project]/keys/
SENTRY_DSN=""


