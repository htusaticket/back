### Interceptor de i18n:

```typescript
// ✅ CORRECTO - Interceptor para i18n automático
@Injectable()
export class I18nInterceptor implements NestInterceptor {
  constructor(private readonly i18n: I18nService) {}

  intercept(context: ExecutionContext, next: CallHandler): Observable<any> {
    const request = context.switchToHttp().getRequest();
    const lang = request.headers['accept-language'] || 'es';

    // Establecer idioma en el contexto
    request.lang = lang;

    return next.handle().pipe(
      catchError((error) => {
        if (error instanceof HttpException) {
          const message = error.message;
          
          // Si el mensaje es una clave de traducción, traducirla
          if (typeof message === 'string' && message.includes('.')) {
            const translatedMessage = this.i18n.t(message, { lang });
            
            // Crear nueva excepción con mensaje traducido
            const newError = new (error.constructor as any)(
              translatedMessage,
              error.getStatus()
            );
            
            throw newError;
          }
        }
        
        throw error;
      })
    );
  }
}
```

### Controladores con i18n:

```typescript
// ✅ CORRECTO - Controladores con soporte de idioma
@Controller('users')
export class UsersController {
  constructor(
    private readonly userService: UserService,
    private readonly i18n: I18nService,
  ) {}

  @Get(':id')
  async findById(
    @Param('id') id: string,
    @Req() request: Request,
  ): Promise<UserResponse> {
    const lang = request.headers['accept-language'] || 'es';
    return this.userService.findById(id, lang);
  }

  @Post()
  async create(
    @Body() createUserDto: CreateUserDto,
    @Req() request: Request,
  ): Promise<UserResponse> {
    const lang = request.headers['accept-language'] || 'es';
    return this.userService.create(createUserDto, lang);
  }
}
```

### Filtro de excepciones con i18n:

```typescript
// ✅ CORRECTO - Filtro global con i18n
@Catch()
export class I18nExceptionFilter implements ExceptionFilter {
  constructor(private readonly i18n: I18nService) {}

  catch(exception: unknown, host: ArgumentsHost): void {
    const ctx = host.switchToHttp();
    const response = ctx.getResponse<Response>();
    const request = ctx.getRequest<Request>();

    const lang = request.headers['accept-language'] || 'es';
    const status = exception instanceof HttpException 
      ? exception.getStatus() 
      : HttpStatus.INTERNAL_SERVER_ERROR;

    let message = exception instanceof HttpException 
      ? exception.message 
      : 'errors.internal.server';

    // Traducir mensaje si es una clave
    if (typeof message === 'string' && message.includes('.')) {
      try {
        message = this.i18n.t(message, { lang });
      } catch (error) {
        // Si no se puede traducir, usar mensaje por defecto
        message = this.i18n.t('errors.internal.server', { lang });
      }
    }

    response.status(status).json({
      success: false,
      statusCode: status,
      message,
      timestamp: new Date().toISOString(),
      path: request.url,
      language: lang,
    });
  }
}
```

### Reglas de i18n:

- **SOPORTAR** al menos español (es) e inglés (en)
- **USAR** claves de traducción en lugar de texto hardcodeado
- **IMPLEMENTAR** fallback a idioma por defecto
- **ESTRUCTURAR** archivos de traducción por módulos
- **INCLUIR** parámetros dinámicos en mensajes
- **DETECTAR** idioma desde headers HTTP
- **VALIDAR** que todas las claves tengan traducción
- **MANTENER** consistencia en estructura de mensajes