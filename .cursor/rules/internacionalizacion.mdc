### Uso en servicios:

```typescript
// ✅ CORRECTO - Servicios con i18n
@Injectable()
export class UserService {
  constructor(
    @Inject(USER_REPOSITORY) private readonly userRepository: UserRepository,
    private readonly i18n: I18nService,
  ) {}

  async findById(id: string, lang: string = 'es'): Promise<User> {
    const user = await this.userRepository.findById(id);
    
    if (!user) {
      throw new NotFoundException(
        this.i18n.t('errors.user.notFound', { 
          lang, 
          args: { id } 
        })
      );
    }

    return user;
  }

  async create(createUserDto: CreateUserDto, lang: string = 'es'): Promise<User> {
    // Validar email único
    const existingUser = await this.userRepository.findByEmail(createUserDto.email);
    if (existingUser) {
      throw new ConflictException(
        this.i18n.t('errors.user.alreadyExists', { 
          lang, 
          args: { field: 'email' } 
        })
      );
    }

    return this.userRepository.create(createUserDto);
  }
}
```

