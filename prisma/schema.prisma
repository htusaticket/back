// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// Enums
enum UserRole {
  SUPERADMIN    // Control total del sistema
  ADMIN         // Teachers - pueden gestionar clases y correcciones
  USER          // Alumnos
  JOB_UPLOADER  // Rol especial para subir ofertas de trabajo
}

enum UserStatus {
  PENDING    // Esperando aprobación del registro
  ACTIVE     // Aprobado - puede o no tener subscripción activa
  SUSPENDED  // Baneado manualmente por admin
}

enum UserPlan {
  PRO         // Nivel 1 - Acceso completo
  ELITE       // Nivel 1 - Acceso completo
  LEVEL_UP    // Nivel 1 - Acceso completo
  HIRING_HUB  // Nivel 2 - Contenido + Job Board (sin clases en vivo)
  SKILL_BUILDER // Nivel 3 - Solo contenido
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum ClassType {
  REGULAR
  WORKSHOP
  WEBINAR
  QA
  MASTERCLASS
}

enum ChallengeType {
  AUDIO
  MULTIPLE_CHOICE
  WRITING
}

enum EnrollmentStatus {
  CONFIRMED
  CANCELLED
}

enum AttendanceStatus {
  NOT_MARKED
  PRESENT
  LATE
  ABSENT
}

enum SubmissionStatus {
  PENDING
  APPROVED
  NEEDS_IMPROVEMENT
}

enum ResourceType {
  PDF
  LINK
  VIDEO
  DOCUMENT
}

enum ModuleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NotificationType {
  STRIKE_APPLIED
  CLASS_REMINDER
  MATERIAL_AVAILABLE
  CHALLENGE_FEEDBACK
  CLASS_CONFIRMED
  GENERAL
  NEW_REGISTRATION   // Notificación a admins de nuevo registro
  PLAN_EXPIRED       // Notificación al usuario de plan expirado
  REGISTRATION_APPROVED // Notificación al usuario de registro aprobado
  UPGRADE_REQUEST    // Solicitud de upgrade de plan por parte de un usuario
}

// Modelo base de Usuario
model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  firstName String     @map("first_name")
  lastName  String     @map("last_name")
  phone     String?
  city      String?
  country   String?
  reference String?    // ¿Cómo nos conociste?
  avatar    String?
  role      UserRole   @default(USER)
  status    UserStatus @default(PENDING)
  
  // Campos de castigo por strikes
  isPunished    Boolean   @default(false) @map("is_punished")
  punishedUntil DateTime? @map("punished_until")
  
  // Notas del admin
  adminNotes String?    @map("admin_notes") @db.Text // Notas del admin (JSON con formato)
  
  // Último inicio de sesión
  lastLoginAt DateTime? @map("last_login_at")

  // Relaciones Base
  sessions       UserSession[]
  passwordResets PasswordReset[]

  // Relación de Subscripción
  subscriptions Subscription[]

  // Relaciones Academy
  lessonProgress UserLessonProgress[]
  moduleProgress UserModuleProgress[]

  // Relaciones Classes
  classEnrollments ClassEnrollment[]
  strikes          Strike[]

  // Relaciones Jobs
  jobApplications JobApplication[]

  // Relaciones Challenges
  challengeProgress UserDailyChallengeProgress[]

  // Relaciones Notifications
  notifications Notification[]

  // Auditoría
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([isPunished])
  @@map("users")
}

// ====================================================
// SUBSCRIPTIONS
// ====================================================

model Subscription {
  id        String             @id @default(cuid())
  userId    String             @map("user_id")
  plan      UserPlan
  status    SubscriptionStatus @default(ACTIVE)
  
  // Fechas
  startDate DateTime  @map("start_date")
  endDate   DateTime  @map("end_date")
  
  // Info de pago (manual por SUPERADMIN)
  hasPaid     Boolean  @default(false) @map("has_paid")
  paidAt      DateTime? @map("paid_at")
  paymentNote String?  @map("payment_note") // Nota sobre el pago
  
  // Quién asignó el plan
  assignedBy String?  @map("assigned_by") // ID del admin que asignó
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([endDate])
  @@map("subscriptions")
}

// Tabla para tokens de recuperación de contraseña
model PasswordReset {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_resets")
}

// Tabla para tracking de sesiones/tokens
model UserSession {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  userAgent    String?  @map("user_agent")
  ipAddress    String?  @map("ip_address")
  isValid      Boolean  @default(true) @map("is_valid")
  expiresAt    DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@map("user_sessions")
}

// ====================================================
// ACADEMY / LEARNING
// ====================================================

model Module {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  image       String // URL
  order       Int    @default(0)
  status      ModuleStatus @default(PUBLISHED)
  visibleForSkillBuilder Boolean @default(false) @map("visible_for_skill_builder") // Si es visible para plan SKILL_BUILDER

  lessons      Lesson[]
  userProgress UserModuleProgress[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([order])
  @@map("modules")
}

model Lesson {
  id          Int     @id @default(autoincrement())
  title       String
  description String? @db.Text
  duration    String // e.g. "10 min"
  contentUrl  String? @map("content_url") // Video url or content
  order       Int     @default(0)

  moduleId Int    @map("module_id")
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  userProgress UserLessonProgress[]
  resources    LessonResource[]

  @@index([moduleId])
  @@index([order])
  @@map("lessons")
}

model LessonResource {
  id       Int          @id @default(autoincrement())
  title    String
  fileUrl  String       @map("file_url")
  type     ResourceType @default(PDF)
  size     String?      // e.g. "245 KB"
  lessonId Int          @map("lesson_id")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([lessonId])
  @@map("lesson_resources")
}

model UserLessonProgress {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  lessonId       Int       @map("lesson_id")
  completed      Boolean   @default(false)
  lastAccessedAt DateTime? @map("last_accessed_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, lessonId])
  @@map("user_lesson_progress")
}

model UserModuleProgress {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  moduleId Int    @map("module_id")
  progress Int    @default(0) // 0-100 percentage

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, moduleId])
  @@map("user_module_progress")
}

// ====================================================
// CLASSES / LIVE SESSIONS
// ====================================================

model ClassSession {
  id    Int       @id @default(autoincrement())
  title String
  type  ClassType @default(REGULAR)

  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")

  capacityMax    Int?    @map("capacity_max") // null means unlimited
  meetLink       String? @map("meet_link")
  materialsLink  String? @map("materials_link")
  description    String?

  enrollments ClassEnrollment[]
  strikes     Strike[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([startTime])
  @@map("class_sessions")
}

model ClassEnrollment {
  id               String           @id @default(cuid())
  userId           String           @map("user_id")
  classSessionId   Int              @map("class_session_id")
  enrolledAt       DateTime         @default(now()) @map("enrolled_at")
  status           EnrollmentStatus @default(CONFIRMED)
  cancelledAt      DateTime?        @map("cancelled_at")
  
  // Campo de asistencia
  attendanceStatus AttendanceStatus @default(NOT_MARKED) @map("attendance_status")
  attendanceMarkedAt DateTime?      @map("attendance_marked_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  @@unique([userId, classSessionId])
  @@index([status])
  @@index([attendanceStatus])
  @@map("class_enrollments")
}

model Strike {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  classSessionId Int?     @map("class_session_id") // Opcional para strikes manuales
  reason         String   @default("LATE_CANCELLATION")
  isManual       Boolean  @default(false) @map("is_manual") // Strike emitido manualmente por admin
  createdAt      DateTime @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  classSession ClassSession? @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("strikes")
}

// ====================================================
// CHALLENGES
// ====================================================

model DailyChallenge {
  id           Int           @id @default(autoincrement())
  title        String
  type         ChallengeType
  instructions String        @db.Text
  date         DateTime      // Fecha para la que es el challenge
  questions    Json?         // Para quiz questions (array de objetos)
  audioUrl     String?       @map("audio_url") // Para challenges de audio
  points       Int           @default(10)
  isActive     Boolean       @default(true) @map("is_active")
  visibleForSkillBuilder Boolean @default(false) @map("visible_for_skill_builder") // Si es visible para plan SKILL_BUILDER

  userProgress UserDailyChallengeProgress[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([date])
  @@index([isActive])
  @@map("daily_challenges")
}

model UserDailyChallengeProgress {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  challengeId Int              @map("challenge_id")
  completed   Boolean          @default(false)
  completedAt DateTime?        @map("completed_at")
  answers     Json?            // Respuestas del usuario (para quiz)
  fileUrl     String?          @map("file_url") // URL del archivo subido (para audio)
  status      SubmissionStatus @default(PENDING)
  feedback    String?          @db.Text // Feedback del profesor (solo para audio)
  score       Int?             // Puntaje obtenido

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge DailyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, challengeId])
  @@index([userId, completedAt])
  @@index([status])
  @@map("user_daily_challenge_progress")
}

// ====================================================
// NOTIFICATIONS
// ====================================================

model Notification {
  id      String           @id @default(cuid())
  userId  String           @map("user_id")
  type    NotificationType
  title   String
  message String           @db.Text
  isRead  Boolean          @default(false) @map("is_read")
  data    Json?            // Metadata adicional (classId, challengeId, etc.)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ====================================================
// JOBS
// ====================================================

enum ApplicationStatus {
  APPLIED
  PENDING
  INTERVIEW
  OFFER      // Kept for backwards compatibility with existing data
  REJECTED
}

model JobOffer {
  id           Int      @id @default(autoincrement())
  title        String
  company      String
  location     String   @default("")
  salaryRange  String   @default("") @map("salary_range")
  oteMin       Int      @default(0) @map("ote_min") // OTE minimum in dollars per month
  oteMax       Int      @default(0) @map("ote_max") // OTE maximum in dollars per month
  revenue      Int      @default(0) // Monthly revenue requirement in dollars
  type         String   @default("Setter") // "Setter", "Closer", etc.
  description  String   @default("") @db.Text
  requirements String[] // Supports arrays in Postgres
  isActive     Boolean  @default(true) @map("is_active")
  social       String?  // Primary social link (Instagram, etc.)
  recruiterSocial String? @map("recruiter_social") // Recruiter social link
  website      String?  // Company/recruiter website
  email        String?  @map("contact_email") // Contact email

  applications JobApplication[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([type])
  @@index([oteMax])
  @@index([revenue])
  @@map("job_offers")
}

model JobApplication {
  id         String            @id @default(cuid())
  userId     String            @map("user_id")
  jobOfferId Int               @map("job_offer_id")
  status     ApplicationStatus @default(APPLIED)
  notes      String?           @db.Text // Notas personales del usuario
  appliedAt  DateTime          @default(now()) @map("applied_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobOffer JobOffer @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)

  @@unique([userId, jobOfferId])
  @@index([userId, status])
  @@map("job_applications")
}

// ====================================================
// SYSTEM CONFIGURATION
// ====================================================

model SystemConfig {
  id    String @id @default("default") // Solo habrá un registro
  
  // Configuración de Strikes y Punishment
  strikesEnabled           Boolean @default(true) @map("strikes_enabled") // Si los strikes están habilitados globalmente
  maxStrikesForPunishment  Int @default(3) @map("max_strikes_for_punishment")
  punishmentDurationDays   Int @default(14) @map("punishment_duration_days") // Duración del castigo en días
  lateCancellationHours    Int @default(24) @map("late_cancellation_hours") // Horas antes de clase para cancelación sin strike
  
  // Configuración de visibilidad de features
  jobBoardEnabled Boolean @default(true) @map("job_board_enabled")
  academyEnabled  Boolean @default(true) @map("academy_enabled")
  
  // Auditoría
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

// ====================================================
// AUDIT LOGS
// ====================================================

enum AuditAction {
  // User actions
  USER_CREATED
  USER_APPROVED
  USER_REJECTED
  USER_SUSPENDED
  USER_ACTIVATED
  USER_DELETED
  USER_UPDATED
  USER_STRIKE_ISSUED
  
  // Admin actions
  ADMIN_CREATED
  ADMIN_UPDATED
  ADMIN_DELETED
  
  // Subscription actions
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_UPDATED
  SUBSCRIPTION_CANCELLED
  SUBSCRIPTION_DELETED
  
  // Class actions
  CLASS_CREATED
  CLASS_UPDATED
  CLASS_DELETED
  CLASS_ATTENDANCE_MARKED
  
  // Academy actions
  MODULE_CREATED
  MODULE_UPDATED
  MODULE_DELETED
  MODULES_REORDERED
  LESSON_CREATED
  LESSON_UPDATED
  LESSON_DELETED
  LESSONS_REORDERED
  
  // Challenge actions
  CHALLENGE_CREATED
  CHALLENGE_UPDATED
  CHALLENGE_DELETED
  SUBMISSION_REVIEWED
  
  // Job actions
  JOB_CREATED
  JOB_UPDATED
  JOB_DELETED
  
  // System actions
  SYSTEM_CONFIG_UPDATED
  LOGIN_SUCCESS
  LOGIN_FAILED
}

model AuditLog {
  id          String      @id @default(cuid())
  
  // Who performed the action
  adminId     String      @map("admin_id")
  adminEmail  String      @map("admin_email")
  adminName   String      @map("admin_name")
  
  // What action was performed
  action      AuditAction
  
  // Target of the action (e.g., user id, class id, etc.)
  targetType  String?     @map("target_type") // "USER", "CLASS", "MODULE", etc.
  targetId    String?     @map("target_id")
  targetName  String?     @map("target_name") // Descriptive name
  
  // Additional details
  details     Json?       // Additional context about the action
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent")
  
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([adminId])
  @@index([action])
  @@index([targetType])
  @@index([createdAt])
  @@map("audit_logs")
}
